<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<div class="container mt-4">

    <h1>Deliveries</h1>

    <table class="table table-bordered table-striped">

        <thead>

            <tr>

                <th>ID</th>
                <th>Status</th>
                <th>Courier</th>
                <th>Accepted At</th>
                <th>Delivered At</th>
                <th>Actions</th>

            </tr>

        </thead>

        <tbody>

            <% deliveries.forEach(delivery => { %>

                <tr>

                    <td>
                        <%= delivery._id %>
                    </td>

                    <td>
                        <%= delivery.status %>
                    </td>

                    <td>

                        <% if(delivery.courier) { %>

                            <%= delivery.courier %>

                        <% } else { %>

                            Not assigned

                        <% } %>

                    </td>

                    <td>

                        <% if(delivery.acceptedAt) { %>

                            <%= delivery.acceptedAt.toLocaleString() %>

                        <% } else { %>

                            -

                        <% } %>

                    </td>

                    <td>

                        <% if(delivery.deliveredAt) { %>

                            <%= delivery.deliveredAt.toLocaleString() %>

                        <% } else { %>

                            -

                        <% } %>

                    </td>

                    <td>

                        <% if(user && user.role === 'courier') { %>

                            <% if(delivery.status === 'available') { %>

                                <form
                                    method="POST"
                                    action="/deliveries/accept/<%= delivery._id %>"
                                >

                                    <button class="btn btn-success">

                                        Accept Delivery

                                    </button>

                                </form>

                            <% } %>

                        <% } %>

                        <% if(
                            user &&
                            user.role === 'courier' &&
                            delivery.courier &&
                            delivery.status !== 'delivered'
                        ) { %>

                            <form
                                method="POST"
                                action="/deliveries/status/<%= delivery._id %>"
                            >

                                <select
                                    name="status"
                                    class="form-select"
                                >

                                    <option value="accepted">
                                        Accepted
                                    </option>

                                    <option value="in_transit">
                                        In Transit
                                    </option>

                                    <option value="delivered">
                                        Delivered
                                    </option>

                                </select>

                                <br>

                                <button class="btn btn-primary">

                                    Update Status

                                </button>

                            </form>

                        <% } %>

                    </td>

                </tr>

            <% }) %>

        </tbody>

    </table>

</div>

<%- include('../partials/foot') %>