<%- include('./partials/head') %>
<%- include('./partials/nav') %>

<!-- HERO -->
<section class="hero-section text-center">

    <div class="container">

        <!-- LOGO -->
        <img
            src="/images/logo.png"
            alt="Logo"
            class="hero-logo mb-4"
        >

        <p class="lead mt-3">

            Your smart supermarket delivery platform

        </p>

        <div class="mt-5">

    <!-- MAIN ACTIONS -->
    <a
        href="/products"
        class="btn btn-light btn-lg me-3"
    >

        Browse Products

    </a>

    <a
        href="/supermarkets"
        class="btn btn-outline-light btn-lg me-3"
    >

        Supermarkets

    </a>

</div>

      <!-- AUTH ACTIONS -->
      <div class="mt-4">

          <a
              href="/auth/login"
              class="btn btn-primary btn-lg me-3"
          >

              Login

          </a>

          <a
              href="/auth/register"
              class="btn btn-outline-light btn-lg"
          >

              Register

          </a>

      </div>

    </div>

</section>

<!-- FEATURES -->
<section class="container mt-5">

    <div class="row text-center">

        <!-- FEATURE 1 -->
        <div class="col-md-4 mb-4">

            <div class="card feature-card shadow border-0 h-100">

                <div class="card-body">

                    <h3 class="text-primary">

                        Fast Delivery

                    </h3>

                    <p>

                        Receive your products quickly
                        through our courier system.

                    </p>

                </div>

            </div>

        </div>

        <!-- FEATURE 2 -->
        <div class="col-md-4 mb-4">

            <div class="card feature-card shadow border-0 h-100">

                <div class="card-body">

                    <h3 class="text-primary">

                        Trusted Supermarkets

                    </h3>

                    <p>

                        Browse supermarkets and
                        discover quality products.

                    </p>

                </div>

            </div>

        </div>

        <!-- FEATURE 3 -->
        <div class="col-md-4 mb-4">

            <div class="card feature-card shadow border-0 h-100">

                <div class="card-body">

                    <h3 class="text-primary">

                        Easy Shopping

                    </h3>

                    <p>

                        Modern and intuitive
                        shopping experience.

                    </p>

                </div>

            </div>

        </div>

    </div>

</section>

