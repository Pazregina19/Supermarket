<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<div class="container mt-5">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h1>
                Products
            </h1>

            <p class="text-muted">
                Browse all available products
            </p>

        </div>

        <a
            href="/products/create"
            class="btn btn-success"
        >

            + Create Product

        </a>

    </div>

    <!-- SEARCH -->
    <form
        method="GET"
        action="/products"
        class="mb-5"
    >

        <div class="input-group">

            <input
                type="text"
                name="search"
                class="form-control"
                placeholder="Search product..."
                value="<%= typeof search !== 'undefined' ? search : '' %>"
            >

            <button
                type="submit"
                class="btn btn-dark"
            >

                Search

            </button>

        </div>

    </form>

    <!-- PRODUCTS -->
    <div class="row">

        <% if(products.length === 0) { %>

            <div class="col-12">

                <div class="alert alert-warning">

                    No products found.

                </div>

            </div>

        <% } else { %>

            <% products.forEach(product => { %>

                <div class="col-lg-4 col-md-6 mb-4">

                    <div class="card shadow h-100 border-0">

                        <!-- IMAGE -->
                        <img
                            src="/uploads/<%= product.image || 'default.jpg' %>"
                            class="card-img-top"
                            style="
                                height: 250px;
                                object-fit: cover;
                            "
                        >

                        <!-- BODY -->
                        <div class="card-body d-flex flex-column">

                            <!-- NAME -->
                            <h4 class="card-title">

                                <%= product.name %>

                            </h4>

                            <!-- CATEGORY -->
                            <span class="badge bg-dark mb-2">

                                <%= product.category %>

                            </span>

                            <!-- DESCRIPTION -->
                            <p class="text-muted">

                                <%= product.description %>

                            </p>

                            <!-- PRICE -->
                            <h3 class="text-success">

                                €<%= product.price %>

                            </h3>

                            <!-- STOCK -->
                            <% if(product.stock > 0) { %>

                                <p>

                                    <span class="badge bg-success">

                                        In Stock:
                                        <%= product.stock %>

                                    </span>

                                </p>

                            <% } else { %>

                                <p>

                                    <span class="badge bg-danger">

                                        Out of Stock

                                    </span>

                                </p>

                            <% } %>

                            <!-- SUPERMARKET -->
                            <p>

                                <strong>
                                    Supermarket:
                                </strong>

                                <% if(product.supermarket) { %>

                                    <%= product.supermarket.name %>

                                <% } else { %>

                                    No supermarket

                                <% } %>

                            </p>

                            <!-- ACTIONS -->
                            <div class="mt-auto">

                                <!-- ADD TO CART -->
                                <form
                                    action="/cart/add/<%= product._id %>"
                                    method="POST"
                                >

                                    <button
                                        type="submit"
                                        class="btn btn-primary w-100 mb-2"
                                    >

                                        Add to Cart

                                    </button>

                                </form>

                                <!-- EDIT -->
                                <a
                                    href="/products/edit/<%= product._id %>"
                                    class="btn btn-warning w-100 mb-2"
                                >

                                    Edit

                                </a>

                                <!-- DELETE -->
                                <a
                                    href="/products/delete/<%= product._id %>"
                                    class="btn btn-danger w-100"
                                    onclick="
                                        return confirm(
                                            'Delete product?'
                                        )
                                    "
                                >

                                    Delete

                                </a>

                            </div>
                        </div>

                    </div>

                </div>

            <% }) %>

        <% } %>

    </div>

</div>

<%- include('../partials/foot') %>