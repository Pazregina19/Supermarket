
<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<div>
  <form class="auth">
    <div class="form-text login error"></div>

    <div class="mb-3">
      <label for="email" class="form-label">Email</label>
      <input type="email" class="form-control" id="email" name="email" required>
    </div>

    <br>

    <div class="mb-3">
      <label for="password" class="form-label">Password</label>
      <input type="password" class="form-control" id="password" name="password" required>
    </div>

    <br>

    <button type="submit" class="btn btn-primary" id="loginBtn">Log-In</button><br>
    <a href="/auth/register">Register</a>
  </form>
</div>

<script>
  const form = document.querySelector('form');
  const loginErr = document.querySelector('.login.error');
  const loginBtn = document.getElementById('loginBtn');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    loginErr.textContent = '';
    loginBtn.disabled = true;
    loginBtn.textContent = 'Logging in...';

    const email = form.email.value;
    const password = form.password.value;

    fetch('/auth/login', {
        method: 'POST',
        body: JSON.stringify({ email, password }),
        headers: { 'Content-Type': 'application/json' }
      })
      .then(res => res.json())
      .then(data => {
        if (data.error) {
          loginErr.textContent = data.error.msg;
          loginBtn.disabled = false;
          loginBtn.textContent = 'Log-In';
          return;
        }
        if (data.user) {
    location.assign('/');
    }
      })
      .catch(() => {
        loginErr.textContent = 'Something went wrong. Please try again.';
        loginBtn.disabled = false;
        loginBtn.textContent = 'Log-In';
      });
  });
</script>

<%- include('../partials/foot') %>