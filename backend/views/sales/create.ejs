<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<div class="container mt-5">

    <div class="row">

        <!-- LEFT -->
        <div class="col-lg-8">

            <h1 class="mb-4">
                Create Sale
            </h1>

            <form
                action="/sales/create"
                method="POST"
            >

                <!-- CUSTOMER -->
                <div class="card shadow p-4 mb-4">

                    <h4 class="mb-3">
                        Customer Information
                    </h4>

                    <label class="form-label">
                        Customer Email
                    </label>

                    <input
                        type="email"
                        name="customerEmail"
                        required
                        class="form-control"
                    >

                </div>

                <!-- DELIVERY -->
                <div class="card shadow p-4 mb-4">

                    <h4 class="mb-3">
                        Delivery Options
                    </h4>

                    <label class="form-label">
                        Delivery Method
                    </label>

                    <select
                        name="deliveryMethod"
                        id="deliveryMethod"
                        class="form-select mb-3"
                    >

                        <option value="pickup">
                            Store Pickup
                        </option>

                        <option value="courier">
                            Courier Delivery
                        </option>

                    </select>

                    <label class="form-label">
                        Delivery Address
                    </label>

                    <input
                        type="text"
                        name="deliveryAddress"
                        id="deliveryAddress"
                        class="form-control"
                        placeholder="Street, City, Postal Code"
                    >

                </div>

                <!-- PRODUCTS -->
                <div class="card shadow p-4 mb-4">

                    <h4 class="mb-4">
                        Products
                    </h4>

                    <% if(products.length === 0) { %>

                        <div class="alert alert-warning">

                            No products available.

                        </div>

                    <% } else { %>

                        <div class="row">

                            <% products.forEach(product => { %>

                                <div class="col-md-6 mb-4">

                                    <div class="card h-100 border">

                                        <!-- IMAGE -->
                                        <img
                                            src="/images/<%= product.image %>"
                                            class="card-img-top"
                                            style="
                                                height: 220px;
                                                object-fit: cover;
                                            "
                                        >

                                        <div class="card-body">

                                            <h5>
                                                <%= product.name %>
                                            </h5>

                                            <p class="text-muted">

                                                <%= product.description %>

                                            </p>

                                            <p>

                                                <strong>
                                                    €<%= product.price %>
                                                </strong>

                                            </p>

                                            <p>

                                                Stock:
                                                <%= product.stock %>

                                            </p>

                                            <!-- HIDDEN ID -->
                                            <input
                                                type="hidden"
                                                name="productIds[]"
                                                value="<%= product._id %>"
                                            >

                                            <!-- QUANTITY -->
                                            <label>
                                                Quantity
                                            </label>

                                            <input
                                                type="number"
                                                name="quantities[]"
                                                min="0"
                                                max="<%= product.stock %>"
                                                value="0"
                                                data-price="<%= product.price %>"
                                                class="form-control quantity-input"
                                            >

                                        </div>

                                    </div>

                                </div>

                            <% }) %>

                        </div>

                    <% } %>

                </div>

                <!-- SUBMIT -->
                <button
                    type="submit"
                    class="btn btn-success btn-lg"
                >

                    Complete Sale

                </button>

            </form>

        </div>

        <!-- RIGHT -->
        <div class="col-lg-4">

            <div class="card shadow p-4 sticky-top">

                <h3 class="mb-3">
                    Order Summary
                </h3>

                <hr>

                <p>

                    Delivery Cost:
                    €<span id="deliveryCost">0.00</span>

                </p>

                <h2 class="text-success">

                    Total:
                    €<span id="total">0.00</span>

                </h2>

            </div>

        </div>

    </div>

</div>

<!-- SCRIPT -->
<script>

    const qtyInputs =
    document.querySelectorAll('.quantity-input');

    const deliveryMethod =
    document.getElementById('deliveryMethod');

    const totalEl =
    document.getElementById('total');

    const deliveryCostEl =
    document.getElementById('deliveryCost');

    function getDeliveryCost() {

        return deliveryMethod.value === 'courier'
        ? 5
        : 0;
    }

    function calculateTotal() {

        let total = 0;

        qtyInputs.forEach(input => {

            const qty =
            parseInt(input.value) || 0;

            const price =
            parseFloat(input.dataset.price) || 0;

            total += qty * price;
        });

        const deliveryCost =
        getDeliveryCost();

        total += deliveryCost;

        totalEl.innerText =
        total.toFixed(2);

        deliveryCostEl.innerText =
        deliveryCost.toFixed(2);
    }

    qtyInputs.forEach(input => {

        input.addEventListener(
            'input',
            calculateTotal
        );

    });

    deliveryMethod.addEventListener(
        'change',
        calculateTotal
    );

    calculateTotal();

</script>

<%- include('../partials/foot') %>